// Expected output for weapons_raw.json
// Generated by mdix-converter with threshold=0, min_occurrences=2

@CONFIG(
  version  -> "1.0.0"
  features -> "data"
)

@ENUMS(
  Rarity { COMMON = 0, RARE = 1, UNCOMMON = 2 }
  Type   { BOW = 0, STAFF = 1, SWORD = 2 }
)

@QUICKFUNCS(
  ~weapon<object>(id, name, type, rarity, damage, sell, buy) {
    return {
      id     = id
      name   = name
      type   = type
      rarity = rarity
      damage = damage
      sell   = sell
      buy    = buy
    }
  }
)

@DATA(
  weapons::
    weapon("IRON_SWORD",   "Iron Sword",   Type.SWORD, Rarity.COMMON,   25, 50,  200)
    weapon("STEEL_SWORD",  "Steel Sword",  Type.SWORD, Rarity.UNCOMMON, 45, 90,  360)
    weapon("ELVEN_BLADE",  "Elven Blade",  Type.SWORD, Rarity.RARE,     80, 160, 640)
    weapon("HUNTING_BOW",  "Hunting Bow",  Type.BOW,   Rarity.COMMON,   20, 40,  160)
    weapon("STORM_BOW",    "Storm Bow",    Type.BOW,   Rarity.RARE,     70, 140, 560)
    weapon("OAK_STAFF",    "Oak Staff",    Type.STAFF, Rarity.COMMON,   18, 36,  144)
    weapon("CRYSTAL_STAFF","Crystal Staff",Type.STAFF, Rarity.RARE,     65, 130, 520)
)
